{
  "name": "obsidian-nexus",
  "version": "0.1.0",
  "description": "Semantic Knowledge Graph & Bidirectional Links for Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production && cp manifest.json styles.css dist/ 2>/dev/null || true",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "test": "jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "semantic",
    "graph",
    "links"
  ],
  "author": "Kharizma & Latreia",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^16.11.21",
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.62.0",
    "builtin-modules": "^3.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "jest": "^29.5.0",
    "obsidian": "latest",
    "ts-jest": "^29.1.0",
    "tslib": "2.3.1",
    "typescript": "^5.9.3"
  }
}
